{
  // === CONFIGURAГ‡Г•ES DE FORMATAГ‡ГѓO AUTOMГЃTICA ===
  // Formata arquivo ao salvar (Ctrl+S)
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  // Define formatador especГ­fico por linguagem
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  // AГ§Гµes automГЎticas ao salvar arquivo
  "editor.codeActionsOnSave": {
    // Corrige todos os problemas do ESLint automaticamente
    "source.fixAll.eslint": "explicit"
  },
  // ForГ§a respeito Г s regras do ESLint mesmo usando Prettier
  "prettier.eslintIntegration": true,
  // === CONFIGURAГ‡Г•ES VISUAIS DO EDITOR ===
  // Linha vertical aos 100 caracteres (guia de largura)
  "editor.rulers": [
    100
  ],
  // Tamanho da indentaГ§ГЈo (deve corresponder ao Prettier)
  "editor.tabSize": 2,
  // Usar espaГ§os em vez de tabs
  "editor.insertSpaces": true,
  // Quebra automГЎtica de linhas visuais (nГЈo adiciona \n)
  "editor.wordWrap": "on",
  // Mostra espaГ§os em branco como pontos pequenos
  "editor.renderWhitespace": "boundary",
  // === CONFIGURAГ‡Г•ES DE ARQUIVOS ===
  // Tipo de quebra de linha (importante para consistГЄncia entre OS)
  "files.eol": "\n",
  // Remove espaГ§os em branco no final das linhas
  "files.trimTrailingWhitespace": true,
  // Adiciona linha vazia no final do arquivo
  "files.insertFinalNewline": true,
  // Remove mГєltiplas linhas vazias consecutivas
  "files.trimFinalNewlines": true,
  // Salva automaticamente apГіs delay
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  // === CONFIGURAГ‡Г•ES DE JAVASCRIPT/REACT ===
  // PreferГЄncia por imports relativos em vez de absolutos
  "javascript.preferences.importModuleSpecifier": "relative",
  // Sugere imports automГЎticos
  "javascript.suggest.autoImports": true,
  // Atualiza imports automaticamente ao mover arquivos
  "javascript.updateImportsOnFileMove.enabled": "always",
  // ValidaГ§ГЈo ativada
  "javascript.validate.enable": true,
  // === CONFIGURAГ‡Г•ES DO EMMET ===
  // Habilita Emmet em arquivos JavaScript (para JSX)
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },
  // Trigger do Emmet em JSX
  "emmet.triggerExpansionOnTab": true,
  // === CONFIGURAГ‡Г•ES PARA TAILWIND CSS v4 ===
  // ConfiguraГ§Гµes do CSS IntelliSense
  "css.validate": true,
  "css.lint.unknownAtRules": "ignore",
  "scss.validate": true,
  "scss.lint.unknownAtRules": "ignore",
  "less.validate": true,
  "less.lint.unknownAtRules": "ignore",
  // ConfiguraГ§ГЈo para Tailwind CSS v4 (sem arquivo de config)
  "tailwindCSS.experimental.configFile": null,
  // Regex patterns para detectar classes Tailwind em funГ§Гµes como cn(), clsx(), cva()
  "tailwindCSS.experimental.classRegex": [
    // === FUNГ‡Г•ES DE UTILITY CLASSES ===
    // cn() - class names utility
    [
      "cn\\(([^)]*)\\)",
      "'([^']*)'"
    ],
    [
      "cn\\(([^)]*)\\)",
      "\"([^\"]*)\""
    ],
    [
      "cn\\(([^)]*)\\)",
      "`([^`]*)`"
    ],
    // clsx() - classnames library
    [
      "clsx\\(([^)]*)\\)",
      "'([^']*)'"
    ],
    [
      "clsx\\(([^)]*)\\)",
      "\"([^\"]*)\""
    ],
    [
      "clsx\\(([^)]*)\\)",
      "`([^`]*)`"
    ],
    // classnames() - original classnames package
    [
      "classnames\\(([^)]*)\\)",
      "'([^']*)'"
    ],
    [
      "classnames\\(([^)]*)\\)",
      "\"([^\"]*)\""
    ],
    // cx() - shorthand comum
    [
      "cx\\(([^)]*)\\)",
      "(?:'|\"|`)([^']*)(?:'|\"|`)"
    ],
    // classList() - utility personalizada
    [
      "classList\\(([^)]*)\\)",
      "'([^']*)'"
    ],
    [
      "classList\\(([^)]*)\\)",
      "\"([^\"]*)\""
    ],
    // === CLASS VARIANCE AUTHORITY (CVA) ===
    // cva() - definiГ§Гµes de variantes
    [
      "cva\\(([^)]*)\\)",
      "[\"'`]([^\"'`]*).*?[\"'`]"
    ],
    [
      "cva\\(\\s*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // Variantes dentro de objetos cva
    [
      "variants\\s*:\\s*\\{[^}]*\\}"
    ],
    [
      "compoundVariants\\s*:\\s*\\[[^\\]]*\\]"
    ],
    // === TEMPLATE LITERALS E STYLED COMPONENTS ===
    // tw`` - template literals
    [
      "tw`([^`]*)`"
    ],
    [
      "tw\\.[^`]+`([^`]*)`"
    ],
    // styled-components com tailwind
    [
      "styled\\.[^`]+`([^`]*)`"
    ],
    [
      "css`([^`]*)`"
    ],
    // === JSX ATTRIBUTES ===
    // className prop
    [
      "className\\s*=\\s*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // className com template literals
    [
      "className\\s*=\\s*{\\s*`([^`]*)`"
    ],
    [
      "className\\s*=\\s*{\\s*'([^']*)'"
    ],
    [
      "className\\s*=\\s*{\\s*\"([^\"]*)\""
    ],
    // className com expressГµes condicionais
    [
      "className\\s*=\\s*{[^}]*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // === OBJETOS E ARRAYS DE CLASSES ===
    // Arrays de classes
    [
      "\\[[^\\]]*[\"'`]([^\"'`]*)[\"'`][^\\]]*\\]"
    ],
    // Objetos com classes condicionais
    [
      "{[^}]*[\"'`]([^\"'`]*)[\"'`]\\s*:",
      "\\1"
    ],
    // === FRAMEWORKS ESPECГЌFICOS ===
    // Next.js - styled-jsx
    [
      "jsx`([^`]*)`"
    ],
    // Emotion
    [
      "@emotion/styled.*`([^`]*)`"
    ],
    // === FUNГ‡Г•ES CUSTOMIZADAS COMUNS ===
    // twMerge() - tailwind-merge
    [
      "twMerge\\(([^)]*)\\)",
      "'([^']*)'"
    ],
    [
      "twMerge\\(([^)]*)\\)",
      "\"([^\"]*)\""
    ],
    // twJoin() - tailwind-merge
    [
      "twJoin\\(([^)]*)\\)",
      "'([^']*)'"
    ],
    // merge() - funГ§ГЈo genГ©rica de merge
    [
      "merge\\(([^)]*)\\)",
      "'([^']*)'"
    ],
    // === VARIГЃVEIS E CONSTANTES ===
    // DeclaraГ§Гµes de variГЎveis com classes
    [
      "const\\s+\\w+\\s*=\\s*[\"'`]([^\"'`]*)[\"'`]"
    ],
    [
      "let\\s+\\w+\\s*=\\s*[\"'`]([^\"'`]*)[\"'`]"
    ],
    [
      "var\\s+\\w+\\s*=\\s*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // === HOOKS E COMPOSABLES ===
    // useClassName() - hook customizado
    [
      "useClassName\\([^)]*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // useStyles() - hook customizado
    [
      "useStyles\\([^)]*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // === CONFIGURAГ‡Г•ES DE COMPONENTES ===
    // defaultProps
    [
      "defaultProps\\s*=\\s*{[^}]*className\\s*:\\s*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // Props interfaces (TypeScript)
    [
      "className\\?\\s*:\\s*string"
    ],
    // === COMENTГЃRIOS E ANOTAГ‡Г•ES ===
    // Classes em comentГЎrios (para referГЄncia)
    [
      "//\\s*@tw\\s+([^\\n\\r]*)"
    ],
    [
      "/\\*\\s*@tw\\s+([^*]*)\\*/"
    ],
    // === CASOS ESPECIAIS ===
    // String interpolation dentro de funГ§Гµes
    [
      "\\$\\{[^}]*[\"'`]([^\"'`]*)[\"'`][^}]*\\}"
    ],
    // Ternary operators com classes
    [
      "\\?\\s*[\"'`]([^\"'`]*)[\"'`]\\s*:"
    ],
    [
      ":\\s*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // Classes em arrays de objetos (para mapeamento)
    [
      "\\{[^}]*class(?:Name)?\\s*:\\s*[\"'`]([^\"'`]*)[\"'`]"
    ],
    // Spread de classes
    [
      "\\.\\.\\.[^,}]*[\"'`]([^\"'`]*)[\"'`]"
    ]
  ],
  // === CONFIGURAГ‡Г•ES ADICIONAIS PARA MELHOR DETECГ‡ГѓO ===
  // Inclui mais tipos de arquivo para anГЎlise
  "tailwindCSS.includeLanguages": {
    "javascript": "javascript",
    "javascriptreact": "javascript",
    "typescript": "javascript",
    "typescriptreact": "javascript",
    "html": "html",
    "vue": "vue",
    "svelte": "svelte",
    "astro": "html",
    "solid": "javascript",
    "qwik": "javascript"
  },
  // Habilita validaГ§ГЈo em todos os contextos
  "tailwindCSS.validate": true,
  // Melhora sugestГµes em strings
  "tailwindCSS.suggestions": true,
  // Habilita lint para classes desconhecidas
  "tailwindCSS.lint.invalidApply": "error",
  "tailwindCSS.lint.invalidScreen": "error",
  "tailwindCSS.lint.invalidVariant": "error",
  "tailwindCSS.lint.invalidConfigPath": "error",
  "tailwindCSS.lint.invalidTailwindDirective": "error",
  // === CONFIGURAГ‡Г•ES PARA MELHOR PERFORMANCE ===
  // Limita a busca apenas aos arquivos relevantes
  "tailwindCSS.files.exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/.nuxt/**"
  ],
  // Habilita hover info e autocomplete do Tailwind
  "tailwindCSS.emmetCompletions": true,
  // === CONFIGURAГ‡Г•ES DO ESLINT ===
  // Executa ESLint em arquivos JavaScript e JSX
  "eslint.validate": [
    "javascript",
    "javascriptreact"
  ],
  // === CONFIGURAГ‡Г•ES DE BRACKETPAIR COLORIZATION ===
  // Colore pares de parГЄnteses/chaves para facilitar leitura
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  // === CONFIGURAГ‡Г•ES DE SUGESTГ•ES ===
  // Mostra sugestГµes rapidamente
  "editor.quickSuggestionsDelay": 0,
  // Habilita sugestГµes em strings (Гєtil para classes CSS)
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  // === CONFIGURAГ‡Г•ES DE GIT ===
  // Mostra mudanГ§as inline no editor
  "diffEditor.ignoreTrimWhitespace": false,
  // Auto fetch do git
  "git.autofetch": true,
  // Confirma sync automaticamente
  "git.confirmSync": false,
  // === CONFIGURAГ‡Г•ES ESPECГЌFICAS POR LINGUAGEM ===
  // ConfiguraГ§Гµes especГ­ficas para JavaScript
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  // ConfiguraГ§Гµes especГ­ficas para JSX
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  // ConfiguraГ§Гµes para JSON
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.quickSuggestions": {
      "strings": true
    }
  },
  // ConfiguraГ§Гµes para CSS
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.suggest.insertMode": "replace",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    }
  },
  // === CONFIGURAГ‡Г•ES DE PERFORMANCE ===
  // Exclui pastas da busca para melhorar performance
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/.nuxt": true,
    "**/coverage": true
  },
  // Exclui pastas do file watcher para melhorar performance
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  // Oculta arquivos desnecessГЎrios no explorer
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  "cSpell.language": "en,pt,pt-BR"
}
