# ============================================================================
# ARQUIVO DE EXEMPLO - .env variables reference
# ============================================================================
# Copie como .env, .env.homologation, .env.mock ou .env.production.
# A composição das URLs acontece no vite.config.js a partir das partes abaixo.
# ============================================================================

# ===== FRONTEND (Penelope Web) =====
# URL composta como: {FRONT_PROTOCOL}://{FRONT_IP}:{FRONT_PORT}
FRONT_MODEL=development        # development | homologation | mock | production
FRONT_VERSION=dev              # Versão da aplicação
FRONT_NAME=Corretora Penelope  # Nome exibido no painel
FRONT_PROTOCOL=http
FRONT_IP=localhost
FRONT_PORT=3000

# ===== PENELOPEC API REST =====
# URL composta como: {PENELOPEC_PROTOCOL}://{PENELOPEC_IP}:{PENELOPEC_PORT}{PENELOPEC_PATH}
PENELOPEC_PROTOCOL=http
PENELOPEC_IP=localhost
PENELOPEC_PORT=8081
PENELOPEC_PATH=/api/v1

# ===== CAL SERVICE API REST =====
# URL composta como: {CAL_SERVICE_PROTOCOL}://{CAL_SERVICE_IP}:{CAL_SERVICE_PORT}{CAL_SERVICE_PATH}
CAL_SERVICE_PROTOCOL=http
CAL_SERVICE_IP=localhost
CAL_SERVICE_PORT=8090
CAL_SERVICE_PATH=/api/v1

# ===== VIACEP =====
# URL completa — serviço externo, sem composição
VIACEP_URL=https://viacep.com.br/ws

# ============================================================================
# VARIÁVEIS EXPOSTAS via import.meta.env após composição no vite.config:
# ============================================================================
#
#   import.meta.env.FRONT_URL         → URL completa do frontend
#   import.meta.env.FRONT_MODEL       → Modo de execução
#   import.meta.env.FRONT_VERSION     → Versão da aplicação
#   import.meta.env.FRONT_NAME        → Nome da aplicação
#   import.meta.env.PENELOPEC_URL     → URL base da Penelope API REST
#   import.meta.env.CAL_SERVICE_URL   → URL base do Cal Service API REST
#   import.meta.env.VIACEP_URL        → URL base do ViaCEP
#
# ============================================================================