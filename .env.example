# ============================================================================
# ARQUIVO DE EXEMPLO - .env variables reference
# ============================================================================
# Este arquivo mostra todas as variáveis de ambiente disponíveis e como usá-las
# Copie este arquivo como .env, .env.development, .env.production, etc.
# ============================================================================

# ===== FRONTEND (Penelope Web Site) =====
# Configuração da aplicação React + Vite executando no frontend
APP_MODEL=development                    # Modo de execução: development, homologation, production, mock
APP_VERSION=dev                          # Versão da aplicação
FRONT_IP=localhost                       # IP onde o frontend roda (usado para logs/docs)
FRONT_PORT=3000                          # Porta do servidor de desenvolvimento
APP_PORT=3000                            # Alias para FRONT_PORT (usado pelo Vite)
APP_NAME=Corretora Penelope - DEV        # Nome da aplicação (exibido no painel)
APP_URL=http://localhost:3000            # URL completa do frontend (para redirecionamentos)

# ===== BACKEND (Penelope API Rest) =====
# Configuração da API backend (Java + Spring Boot)
BACKEND_IP=localhost                     # IP onde o backend roda
BACKEND_PORT=8081                        # Porta do servidor backend
API_URL=http://localhost:8081/api/v1     # URL completa da API backend (usado pelo Axios)
VITE_API_BASE_URL=http://localhost:8081/api/v1  # Alias para API_URL (compatibilidade)

# ===== CAL SERVICE (Microsserviço de Agendamentos) =====
# Configuração do serviço de calendário (Cal.com integration)
CAL_SERVICE_IP=localhost                 # IP onde o cal-service roda
CAL_SERVICE_PORT=8090                    # Porta do serviço de calendários
VITE_CAL_SERVICE_URL=http://localhost:8090  # URL completa do cal-service

# ===== VIACEP (Serviço Externo de CEP) =====
# Configuração do serviço ViaCEP (API pública de busca de CEP)
VIACEP_IP=viacep.com.br                  # IP/Host do ViaCEP (serviço externo)
VITE_VIACEP_BASE_URL=https://viacep.com.br/ws     # URL da API ViaCEP

# ============================================================================
# RESUMO DE USO NOS ARQUIVOS:
# ============================================================================
# 
# axiosInstance.js:
#   - Usa: import.meta.env.API_URL
#   - Para qual serviço? Backend (Penelope API Rest)
#
# viaCepApi.js:
#   - Usa: import.meta.env.VITE_VIACEP_BASE_URL
#   - Para qual serviço? ViaCEP (externo)
#
# calservice/calServiceApi.js:
#   - Usa: import.meta.env.VITE_CAL_SERVICE_URL
#   - Para qual serviço? Cal Service (agendamentos)
#
# vite.config.js (server):
#   - Usa: env.APP_PORT, env.FRONT_IP
#   - Define a porta e host do servidor de desenvolvimento
#
# ============================================================================
